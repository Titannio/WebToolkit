{
  "extends": "./tsconfig.json",
  // Build-only project:
  // - Emit production artifacts
  // - Never emit tests/specs to dist
  "include": [
    "src",
    "src/**/*.json"
  ],
  "exclude": [
    "src/**/*.test.ts",
    "src/**/*.test.tsx",
    "src/**/*.spec.ts",
    "src/**/*.spec.tsx",
    "src/**/__tests__/**",
    "node_modules",
    "dist"
  ]
}
