{
  "name": "webtoolkit-utils",
  "version": "0.7.2",
  "private": false,
  "description": "Typed utility toolkit for TypeScript projects with explicit entrypoints for browser, server, framework, database, and country modules.",
  "keywords": [
    "utilities",
    "typescript",
    "toolkit",
    "browser",
    "react",
    "node",
    "mongodb"
  ],
  "license": "MIT",
  "type": "module",
  "main": "./dist/public/index.js",
  "types": "./dist/public/index.d.ts",
  "sideEffects": false,
  "files": [
    "dist/**/*",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/public/index.d.ts",
      "import": "./dist/public/index.js",
      "default": "./dist/public/index.js"
    },
    "./async": {
      "types": "./dist/async/index.d.ts",
      "import": "./dist/async/index.js",
      "default": "./dist/async/index.js"
    },
    "./browser": {
      "types": "./dist/browser/index.d.ts",
      "import": "./dist/browser/index.js",
      "default": "./dist/browser/index.js"
    },
    "./browser/media": {
      "types": "./dist/browser/media/index.d.ts",
      "import": "./dist/browser/media/index.js",
      "default": "./dist/browser/media/index.js"
    },
    "./browser/files": {
      "types": "./dist/browser/files/index.d.ts",
      "import": "./dist/browser/files/index.js",
      "default": "./dist/browser/files/index.js"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js",
      "default": "./dist/core/index.js"
    },
    "./countries": {
      "types": "./dist/countries/index.d.ts",
      "import": "./dist/countries/index.js",
      "default": "./dist/countries/index.js"
    },
    "./countries/BR": {
      "types": "./dist/countries/BR/index.d.ts",
      "import": "./dist/countries/BR/index.js",
      "default": "./dist/countries/BR/index.js"
    },
    "./data": {
      "types": "./dist/data/index.d.ts",
      "import": "./dist/data/index.js",
      "default": "./dist/data/index.js"
    },
    "./database/mongodb": {
      "types": "./dist/database/mongodb/index.d.ts",
      "import": "./dist/database/mongodb/index.js",
      "default": "./dist/database/mongodb/index.js"
    },
    "./dates": {
      "types": "./dist/dates/index.d.ts",
      "import": "./dist/dates/index.js",
      "default": "./dist/dates/index.js"
    },
    "./files": {
      "types": "./dist/files/index.d.ts",
      "import": "./dist/files/index.js",
      "default": "./dist/files/index.js"
    },
    "./finance": {
      "types": "./dist/finance/index.d.ts",
