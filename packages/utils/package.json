      "default": "./dist/security/jwt/index.js"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "import": "./dist/server/index.js",
      "default": "./dist/server/index.js"
    },
    "./server/http": {
      "types": "./dist/server/http/index.d.ts",
      "import": "./dist/server/http/index.js",
      "default": "./dist/server/http/index.js"
    },
    "./server/media": {
      "types": "./dist/server/media/index.d.ts",
      "import": "./dist/server/media/index.js",
      "default": "./dist/server/media/index.js"
    },
    "./server/security": {
      "types": "./dist/server/security/index.d.ts",
      "import": "./dist/server/security/index.js",
      "default": "./dist/server/security/index.js"
    },
    "./text": {
      "types": "./dist/text/index.d.ts",
      "import": "./dist/text/index.js",
      "default": "./dist/text/index.js"
    },
    "./types": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/types/index.js",
      "default": "./dist/types/index.js"
    },
    "./ui": {
      "types": "./dist/ui/index.d.ts",
      "import": "./dist/ui/index.js",
      "default": "./dist/ui/index.js"
    },
    "./validation": {
      "types": "./dist/validation/index.d.ts",
      "import": "./dist/validation/index.js",
      "default": "./dist/validation/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "npm run clean && tsc -p tsconfig.build.json",
    "type-check": "tsc --noEmit",
    "clean": "rimraf dist .tsbuildinfo",
    "lint": "eslint src tests",
    "lint:fix": "eslint src tests --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepack": "npm run build",
    "npm:update": "npm update",
    "npm:release": "npm publish"
  },
  "peerDependencies": {
    "express": "^5.1.0",
    "mongoose": "^9.4.1",
    "react": ">=18.0.0",
    "sharp": "^0.33.0 || ^0.34.0"
  },
  "peerDependenciesMeta": {
    "express": {
      "optional": true
    },
    "mongoose": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "sharp": {
      "optional": true
    }
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/react": "^16.3.2",
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^10.2.1",
    "express": "^5.1.0",
    "jsdom": "^29.0.2",
    "mongoose": "^9.4.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "rimraf": "^6.0.1",
    "sharp": "^0.34.5",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.58.2",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "es-toolkit": "^1.45.1",
    "remeda": "^2.33.7",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  }
}