      "default": "./dist/finance/index.js"
    },
    "./frameworks/react": {
      "types": "./dist/frameworks/react/index.d.ts",
      "import": "./dist/frameworks/react/index.js",
      "default": "./dist/frameworks/react/index.js"
    },
    "./frameworks/mantine": {
      "types": "./dist/frameworks/mantine/index.d.ts",
      "import": "./dist/frameworks/mantine/index.js",
      "default": "./dist/frameworks/mantine/index.js"
    },
    "./geo": {
      "types": "./dist/geo/index.d.ts",
      "import": "./dist/geo/index.js",
      "default": "./dist/geo/index.js"
    },
    "./network": {
      "types": "./dist/network/index.d.ts",
      "import": "./dist/network/index.js",
      "default": "./dist/network/index.js"
    },
    "./numbers": {
