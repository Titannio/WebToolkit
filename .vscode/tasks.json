{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "utils: install",
      "type": "shell",
      "command": "npm install",
      "options": {
        "cwd": "${workspaceFolder}/packages/utils"
      },
      "problemMatcher": []
    },
    {
      "label": "utils: build",
      "type": "shell",
      "command": "npm run build",
      "options": {
        "cwd": "${workspaceFolder}/packages/utils"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": [
        "$tsc"
      ]
    },
    {
      "label": "utils: type-check",
      "type": "shell",
      "command": "npm run type-check",
      "options": {
        "cwd": "${workspaceFolder}/packages/utils"
      },
      "problemMatcher": [
        "$tsc"
      ]
    },
    {
      "label": "utils: lint",
      "type": "shell",
      "command": "npm run lint",
      "options": {
        "cwd": "${workspaceFolder}/packages/utils"
      },
      "problemMatcher": [
        "$eslint-stylish"
      ]
    },
    {
      "label": "utils: test",
      "type": "shell",
      "command": "npm test",
      "options": {
        "cwd": "${workspaceFolder}/packages/utils"
      },
      "group": {
        "kind": "test",
        "isDefault": true
      },
      "problemMatcher": []
    },
    {
      "label": "utils: test watch",
      "type": "shell",
      "command": "npm run test:watch",
      "options": {
        "cwd": "${workspaceFolder}/packages/utils"
      },
      "isBackground": true,
      "problemMatcher": []
    },
    {
      "label": "utils: coverage",
      "type": "shell",
      "command": "npm run test:coverage",
      "options": {
        "cwd": "${workspaceFolder}/packages/utils"
      },
      "problemMatcher": []
    },
    {
      "label": "utils: clean",
      "type": "shell",
      "command": "npm run clean",
      "options": {
        "cwd": "${workspaceFolder}/packages/utils"
      },
      "problemMatcher": []
    },
    {
      "label": "utils: prepack check",
      "type": "shell",
      "command": "npm pack --dry-run",
      "options": {
        "cwd": "${workspaceFolder}/packages/utils"
      },
      "problemMatcher": []
    }
  ]
}
